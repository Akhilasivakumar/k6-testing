{
  "title": "k6 Final Integrated Dashboard",
  "uid": "k6-final-dashboard",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 110,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      },
      "options": {
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "value",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(k6_http_reqs_total)",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 112,
      "title": "Avg Response Time",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "value",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "k6_http_req_duration_avg",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 113,
      "title": "Throughput (TPS)",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "options": {
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "value",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "rate(k6_http_reqs_total[1m])",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 1,
      "title": "Active Virtual Users",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "options": {
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "value",
        "justifyMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "k6_vus",
          "legendFormat": "Active VUs",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Request Rate (Over Time)",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "rate(k6_http_reqs_total[1m])",
          "legendFormat": "Requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (Over Time)",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "k6_http_req_failed_rate * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP Request Duration p95 (Over Time)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "k6_http_req_duration_p95",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Request Duration p99 (Over Time)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "k6_http_req_duration_p99",
          "legendFormat": "p99",
          "refId": "A"
        }
      ]
    },
    {
      "id": 300,
      "title": "HTTP Response Status Codes",
      "type": "piechart",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "transformations": [
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^0$",
            "renamePattern": "Network Error (Timeout)"
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^200$",
            "renamePattern": "200 - Success (OK)"
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^404$",
            "renamePattern": "404 - Not Found (Broken Link)"
          }
        },
        {
          "id": "renameByRegex",
          "options": {
            "regex": "^500$",
            "renamePattern": "500 - Server Error (Crash)"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "values": true,
          "calcs": [
            "lastNotNull"
          ]
        },
        "pieType": "donut",
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum by (status) (k6_http_reqs_total)",
          "legendFormat": "{{status}}",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ]
}